# Environment variables for E-Lixo

# Flask Configuration
FLASK_DEBUG=1
SECRET_KEY=seu-chave-secreta-aqui-mudar-em-producao

# Admin Credentials
E_LIXO_ADMIN_USER=admin
E_LIXO_ADMIN_PASS=password

# Server Configuration  
HOST=0.0.0.0
PORT=8000

# Google Cloud Vision API
# Defina para o caminho do arquivo JSON da service account
# Exemplo: GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GOOGLE_APPLICATION_CREDENTIALS=

# (Alternativa para Render) Conteúdo do arquivo JSON como string
# Descomente se usar a abordagem de arquivo no container
# GOOGLE_CLOUD_KEY_JSON={"type": "service_account", ...}
